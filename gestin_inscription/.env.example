# Configuration de base de données
DB_URL=jdbc:postgresql://localhost:5432/gestion_inscription2
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# Configuration JWT
JWT_SECRET=your_super_secret_jwt_key_here_minimum_256_bits
JWT_EXPIRATION=86400000

# Configuration Email
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Configuration Admin
ADMIN_USERNAME=super-admin
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_EMAIL=admin@yourdomain.com

# Configuration OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Configuration reCAPTCHA
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Configuration Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Configuration SSL (Production)
SSL_ENABLED=false
SSL_KEYSTORE_PATH=/path/to/keystore.p12
SSL_KEYSTORE_PASSWORD=your_keystore_password

# Configuration CORS (Production)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Configuration de stockage
SECURE_STORAGE_PATH=/var/sigec/secure-storage